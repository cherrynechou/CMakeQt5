#include <windows.h>
#include "config.h"

// 应用程序图标
#IDI_ICON1 ICON "resources/icon/app.ico"

#define PROJECT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define PROJECT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define PROJECT_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define PROJECT_VERSION_BUILD 0

#define STRINGIFY(x) #x
#define TO_STRING(x) STRINGIFY(x)

#define APP_VERSION_STRING \
  TO_STRING(PROJECT_VERSION_MAJOR) "." \
  TO_STRING(PROJECT_VERSION_MINOR) "." \
  TO_STRING(PROJECT_VERSION_PATCH) "." \
  TO_STRING(PROJECT_VERSION_BUILD)
#define APP_NAME_STRING TO_STRING(APP_NAME)

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 		PROJECT_VERSION_MAJOR, PROJECT_VERSION_MINOR, PROJECT_VERSION_PATCH, PROJECT_VERSION_BUILD
 PRODUCTVERSION 	PROJECT_VERSION_MAJOR, PROJECT_VERSION_MINOR, PROJECT_VERSION_PATCH, PROJECT_VERSION_BUILD
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG  	
	FILEFLAGS 0x1L
#else
	FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L  		
 FILESUBTYPE 0x0L
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "040904B0" // Unicode 编码（正确中文编码）
		BEGIN
		    VALUE "CompanyName", L##APP_COMPANY_NAME
			VALUE "FileDescription", L##APP_FILE_DESCRIPTION 
			VALUE "FileVersion", L##APP_FILE_VERSION
			VALUE "InternalName", L##APP_INTERNAL_NAME
			VALUE "LegalCopyright", L##APP_LEGAL_COPYRIGHT
			VALUE "OriginalFilename", L##APP_ORIGINAL_FILENAME
			VALUE "ProductName", L##APP_NAME_STRING
			VALUE "ProductVersion", L##APP_VERSION_STRING
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x409, 1200   // 1200 = Unicode
	END
END