#include <windows.h>
#include "config.h"

// 解决中文乱码问题
#pragma code_page(65001)
// 应用程序图标
#IDI_ICON1 ICON "resources/icon/app.ico"

#define PROJECT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define PROJECT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define PROJECT_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define PROJECT_VERSION_BUILD 0

#define STRINGIFY(x) #x
#define TO_STRING(x) STRINGIFY(x)

#define APP_VERSION_STRING TO_STRING(PROJECT_VERSION_MAJOR) "." TO_STRING(PROJECT_VERSION_MINOR) "." TO_STRING(PROJECT_VERSION_PATCH) "." TO_STRING(PROJECT_VERSION_BUILD)
#define APP_NAME_STRING TO_STRING(APP_NAME)

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 		  PROJECT_VERSION_MAJOR, PROJECT_VERSION_MINOR, PROJECT_VERSION_PATCH, PROJECT_VERSION_BUILD     //设置文件版本号
 PRODUCTVERSION 	PROJECT_VERSION_MAJOR, PROJECT_VERSION_MINOR, PROJECT_VERSION_PATCH, PROJECT_VERSION_BUILD     //设置产品版本号，代表整体产品的版本（可和文件版本不同）
 FILEFLAGSMASK 0x3fL    //掩码（Mask）用于指定有效的标志位（file flags）
#ifdef _DEBUG  	
	FILEFLAGS 0x1L
#else
	FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L    //#设置目标操作系统 windows 平台固定值
 FILETYPE 0x1L  		//设置文件类型，0x1L 表示 VFT_APP，应用程序（EXE), 0x2L 表示 VFT_DLL 动态库,0x3L  VFT_DRV 驱动程序,
 FILESUBTYPE 0x0L    //文件子类型：普通程序，固定 0x
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "080404B0" // 语言+编码：0804=简体中文，04E4=Windows 编码   英文是 040904E4
		BEGIN
		  VALUE "CompanyName", APP_COMPANY_NAME
			VALUE "FileDescription", APP_FILE_DESCRIPTION 
			VALUE "FileVersion", APP_FILE_VERSION
			VALUE "InternalName", APP_INTERNAL_NAME
			VALUE "LegalCopyright", APP_LEGAL_COPYRIGHT
			VALUE "OriginalFilename", APP_ORIGINAL_FILENAME
			VALUE "ProductName", APP_NAME_STRING
			VALUE "ProductVersion", APP_VERSION_STRING
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x0804, 1200   // 1200 = Unicode  声明：中文 + Windows 编码
	END
END