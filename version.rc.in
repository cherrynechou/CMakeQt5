#include <windows.h>
#include "config.h"

// 应用程序图标
#IDI_ICON1 ICON "resources/icon/app.ico"

#define PROJECT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define PROJECT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define PROJECT_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define PROJECT_VERSION_BUILD 0

#define STRINGIFY(x) #x
#define TO_STRING(x) STRINGIFY(x)

#define APP_VERSION_STRING TO_STRING(VERSION_MAJOR) "." TO_STRING(VERSION_MINOR) "." TO_STRING(VERSION_PATCH) "." TO_STRING(VERSION_BUILD)
#define APP_NAME_STRING TO_STRING(APP_NAME)

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 		PROJECT_VERSION_MAJOR, PROJECT_VERSION_MINOR, PROJECT_VERSION_PATCH, PROJECT_VERSION_BUILD
 PRODUCTVERSION 	PROJECT_VERSION_MAJOR, PROJECT_VERSION_MINOR, PROJECT_VERSION_PATCH, PROJECT_VERSION_BUILD
 FILEFLAGSMASK 0x3fL 	#掩码（Mask）用于指定有效的标志位（file flags）
#ifdef _DEBUG       	#设置文件标志（FileFlags），表示程序构建的状态
	FILEFLAGS 0x1L
#else
	FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L   		#设置目标操作系统
 FILETYPE 0x1L     		#设置文件类型，0x1L 表示 VFT_APP，应用程序（EXE）
 FILESUBTYPE 0x0L  		#子类型，应用程序通常为 0x0L（无子类型）
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "040904E4" // U.S. English
		BEGIN
		    VALUE "CompanyName", APP_COMPANY_NAME
			VALUE "FileDescription", APP_NAME_STR 
			VALUE "FileVersion", APP_VERSION_STRING
			VALUE "InternalName", APP_INTERNAL_NAME
			VALUE "LegalCopyright", APP_LEGAL_COPYRIGHT
			VALUE "OriginalFilename", APP_ORIGINAL_FILENAME
			VALUE "ProductName", APP_NAME_STR
			VALUE "ProductVersion", APP_VERSION_STRING
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x409, 1252
	END
END